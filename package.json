{
  "name": "erc20-deploy",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "type": "module",
  "scripts": {
    "compile": "hardhat compile",
    "typecheck": "tsc --noEmit",
    "test": "hardhat test",
    "test:e2e:anvil": "pnpm run compile && tsx e2e/anvil.e2e.ts",
    "deploy:token": "tsx scripts/deploy-token.ts",
    "deploy:faucet": "wrangler pages deploy faucet-page --project-name usdt-s-faucet",
    "verify:token": "tsx scripts/verify-token.ts"
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.6.1",
    "@openzeppelin/contracts-upgradeable": "5.6.1",
    "dotenv": "17.2.3",
    "ethers": "6.16.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "3.0.4",
    "@types/mocha": "10.0.10",
    "@types/node": "24.10.1",
    "hardhat": "3.4.4",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  }
}
